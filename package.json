{
  "name": "ichnograph",
  "version": "0.4.2",
  "description": "One-screen orientation for any codebase.",
  "type": "module",
  "bin": {
    "ichnograph": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kVadrum/ichnograph.git"
  },
  "homepage": "https://github.com/kVadrum/ichnograph#readme",
  "bugs": {
    "url": "https://github.com/kVadrum/ichnograph/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "codebase",
    "orientation",
    "overview",
    "repository",
    "project",
    "summary",
    "report",
    "structure",
    "tree",
    "stack",
    "stack-detection",
    "git",
    "readme",
    "devtools",
    "zero-dependency"
  ],
  "license": "MIT",
  "author": "kVadrum",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
